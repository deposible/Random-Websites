<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#06060e">
<title>WorldWire — Global News Explorer</title>
<link rel="icon" href='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%23836ef9%22/><text x=%2250%22 y=%2270%22 font-size=%2260%22 text-anchor=%22middle%22>🌐</text></svg>'>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#06060e;--bg2:#0c0c1a;--bg3:#141428;--bg4:#1a1a32;
  --glass:rgba(14,14,30,.85);
  --purple:#836ef9;--purple-soft:#a08aff;--purple-deep:#5a45c9;
  --purple-glow:rgba(131,110,249,.25);
  --cyan:#42e8d5;--green:#3ddc84;--amber:#f5b731;--red:#ff5c6c;
  --text:#eae8f4;--text2:#a09cb8;--text3:#5c5878;--text4:#3a3658;
  --border:rgba(131,110,249,.15);--border2:rgba(131,110,249,.28);
  --map:#1a1830;--map-hover:#2a2848;--map-stroke:#06060e;
  --r:14px;--r-sm:10px;--r-xs:6px;
}
html,body{height:100%}
body{
  font-family:'Syne',sans-serif;background:var(--bg);color:var(--text);
  overflow:hidden;-webkit-font-smoothing:antialiased;
}
.bg-grid{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(131,110,249,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(131,110,249,.025) 1px,transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 80% 70% at 50% 40%,black,transparent);
}
.bg-orb{position:fixed;border-radius:50%;filter:blur(120px);z-index:0;pointer-events:none;will-change:transform;animation:orbF 22s ease-in-out infinite alternate}
.bg-orb.a{width:600px;height:600px;top:-15%;left:-10%;background:rgba(131,110,249,.08)}
.bg-orb.b{width:500px;height:500px;bottom:-15%;right:-10%;background:rgba(66,232,213,.05);animation-delay:-11s}
@keyframes orbF{0%{transform:translate(0,0)}100%{transform:translate(60px,40px)}}

.app{position:relative;z-index:1;display:flex;flex-direction:column;height:100vh;width:100vw}

/* Header */
.header{
  padding:16px 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;
  border-bottom:1px solid var(--border);background:rgba(14,14,30,.6);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);z-index:10;
}
.logo{display:flex;align-items:center;gap:12px}
.logo-mark{
  width:40px;height:40px;border-radius:11px;
  background:linear-gradient(135deg,var(--purple),var(--purple-deep));
  display:flex;align-items:center;justify-content:center;font-size:22px;
  box-shadow:0 0 22px var(--purple-glow),inset 0 1px 0 rgba(255,255,255,.2);
}
.logo-t{font-weight:800;font-size:18px;letter-spacing:-.3px;line-height:1.1}
.logo-t small{display:block;font-weight:400;font-size:10px;color:var(--text3);letter-spacing:.6px;margin-top:2px;text-transform:uppercase}
.search{
  flex:1;max-width:340px;position:relative;
}
.search input{
  width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-sm);
  padding:10px 14px 10px 36px;color:var(--text);font-family:'Syne',sans-serif;font-size:13px;
  outline:none;transition:border-color .2s,box-shadow .2s;
}
.search input:focus{border-color:var(--purple);box-shadow:0 0 0 3px var(--purple-glow)}
.search input::placeholder{color:var(--text4)}
.search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:14px;pointer-events:none}
.search-results{
  position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--bg3);
  border:1px solid var(--border2);border-radius:var(--r-sm);max-height:260px;overflow-y:auto;
  box-shadow:0 12px 40px rgba(0,0,0,.5);display:none;z-index:20;
}
.search-results.open{display:block}
.search-result{
  padding:10px 14px;cursor:pointer;font-size:13px;display:flex;align-items:center;gap:10px;
  border-bottom:1px solid var(--border);transition:background .15s;
}
.search-result:last-child{border-bottom:none}
.search-result:hover,.search-result.hl{background:var(--bg4)}
.search-flag{font-size:16px}
.chips{display:flex;gap:6px;flex-wrap:wrap}
.chip{
  background:var(--bg2);border:1px solid var(--border);color:var(--text2);
  padding:7px 14px;border-radius:20px;font-size:11px;cursor:pointer;
  font-family:'Syne',sans-serif;font-weight:600;transition:all .2s;
  text-transform:uppercase;letter-spacing:.5px;
}
.chip:hover{border-color:var(--purple);color:var(--text)}
.chip.on{background:var(--purple-deep);border-color:var(--purple);color:#fff;box-shadow:0 2px 12px var(--purple-glow)}
.lang-toggle{
  display:flex;background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:3px;
}
.lang-btn{
  background:none;border:none;color:var(--text3);padding:5px 12px;border-radius:16px;
  font-size:10px;cursor:pointer;font-family:'Syne',sans-serif;font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;transition:all .2s;
}
.lang-btn.on{background:var(--purple);color:#fff}

/* Main map */
.main{flex:1;position:relative;overflow:hidden}
.map-svg{width:100%;height:100%;display:block;cursor:grab}
.map-svg:active{cursor:grabbing}
.country{
  fill:var(--map);stroke:var(--map-stroke);stroke-width:.5;
  transition:fill .2s,filter .2s;cursor:pointer;
}
.country:hover{fill:var(--map-hover);filter:brightness(1.2)}
.country.selected{stroke-width:1.5;filter:drop-shadow(0 0 12px currentColor)}
.country.dim{opacity:.25}

/* Map controls */
.controls{
  position:absolute;bottom:24px;right:24px;display:flex;flex-direction:column;gap:6px;
  background:var(--glass);border:1px solid var(--border);border-radius:var(--r-sm);padding:6px;
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
}
.ctrl{
  width:34px;height:34px;background:none;border:none;color:var(--text);cursor:pointer;
  border-radius:var(--r-xs);font-size:16px;font-weight:700;transition:background .15s;
  display:flex;align-items:center;justify-content:center;
}
.ctrl:hover{background:var(--bg4)}
.ctrl:disabled{opacity:.3;cursor:not-allowed}

/* Hint */
.hint{
  position:absolute;bottom:24px;left:24px;font-size:11px;color:var(--text3);
  background:var(--glass);border:1px solid var(--border);border-radius:var(--r-sm);
  padding:10px 14px;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  line-height:1.6;letter-spacing:.3px;pointer-events:none;
}
.hint .kbd{
  background:var(--bg4);border:1px solid var(--border);padding:1px 6px;border-radius:4px;
  font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text2);margin:0 2px;
}

/* Tooltip */
.tooltip{
  position:fixed;background:var(--glass);border:1px solid var(--border2);
  border-radius:var(--r-sm);padding:12px 14px;pointer-events:none;z-index:50;
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);max-width:300px;
  box-shadow:0 8px 32px rgba(0,0,0,.4);opacity:0;transition:opacity .15s;
  font-size:12px;
}
.tooltip.show{opacity:1}
.tooltip .tt-header{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.tooltip .tt-flag{font-size:18px}
.tooltip .tt-name{font-weight:700;font-size:13px;letter-spacing:.2px}
.tooltip .tt-headline{
  color:var(--text);line-height:1.4;font-size:12px;
  overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;
}
.tooltip .tt-source{
  font-size:10px;color:var(--text3);margin-top:6px;
  font-family:'IBM Plex Mono',monospace;
}
.tooltip .tt-loading{color:var(--text3);font-style:italic;font-size:11px}
.tooltip .tt-hint{font-size:10px;color:var(--text4);margin-top:8px;padding-top:6px;border-top:1px solid var(--border);letter-spacing:.3px}

/* Side panel */
.panel{
  position:fixed;top:0;right:0;bottom:0;width:min(440px,92vw);
  background:var(--glass);border-left:1px solid var(--border2);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);z-index:30;
  transform:translateX(100%);transition:transform .4s cubic-bezier(.22,1,.36,1);
  display:flex;flex-direction:column;box-shadow:-12px 0 40px rgba(0,0,0,.4);
}
.panel.open{transform:translateX(0)}
.panel-head{padding:22px 22px 14px;border-bottom:1px solid var(--border);position:relative;flex-shrink:0}
.panel-accent{
  position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--panel-c1,var(--purple)),var(--panel-c2,var(--purple-deep)));
}
.panel-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:8px}
.panel-flag{font-size:34px;line-height:1;margin-bottom:4px}
.panel-name{font-size:22px;font-weight:800;letter-spacing:-.4px;line-height:1.15}
.panel-meta{font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:.3px}
.panel-close{
  background:var(--bg3);border:1px solid var(--border);color:var(--text2);
  width:32px;height:32px;border-radius:var(--r-xs);font-size:18px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;
}
.panel-close:hover{background:var(--bg4);color:var(--red);border-color:var(--red)}
.panel-stats{display:flex;gap:16px;margin-top:10px;flex-wrap:wrap}
.panel-stat{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;font-weight:700}
.panel-stat strong{color:var(--panel-c1,var(--purple-soft));font-family:'IBM Plex Mono',monospace;margin-right:4px}
.panel-body{flex:1;overflow-y:auto;padding:14px 22px 22px}
.panel-body::-webkit-scrollbar{width:6px}
.panel-body::-webkit-scrollbar-track{background:transparent}
.panel-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

.article{
  background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-sm);
  padding:14px;margin-bottom:10px;cursor:pointer;transition:all .2s;position:relative;
  display:block;text-decoration:none;color:inherit;
}
.article:hover{border-color:var(--border2);transform:translateX(-2px);background:var(--bg3)}
.art-img{
  width:100%;height:120px;background:var(--bg);border-radius:var(--r-xs);margin-bottom:10px;
  background-size:cover;background-position:center;position:relative;overflow:hidden;
}
.art-img::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.3),transparent 40%)}
.art-title{font-size:14px;font-weight:700;line-height:1.4;margin-bottom:8px;color:var(--text)}
.art-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace}
.art-source{color:var(--panel-c1,var(--purple-soft));font-weight:600}
.art-lang{background:var(--bg4);padding:1px 6px;border-radius:4px;color:var(--text2);font-size:9px;text-transform:uppercase;letter-spacing:.5px}
.art-date{color:var(--text4)}
.art-ext{position:absolute;top:10px;right:10px;font-size:11px;color:var(--text4);opacity:0;transition:opacity .2s}
.article:hover .art-ext{opacity:1}

.panel-loading{text-align:center;padding:40px 20px;color:var(--text3);font-size:13px}
.spin{display:inline-block;width:14px;height:14px;border:2px solid var(--purple);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;margin-right:8px;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}
.panel-empty{text-align:center;padding:40px 20px;color:var(--text3);font-size:13px;line-height:1.6}
.panel-empty .em{font-size:36px;margin-bottom:12px;display:block;opacity:.5}
.panel-error{text-align:center;padding:30px 20px;color:var(--red);font-size:12px;line-height:1.5}

/* Global view — trending */
.trending{
  position:absolute;top:20px;left:24px;background:var(--glass);border:1px solid var(--border);
  border-radius:var(--r-sm);padding:12px 16px;backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);max-width:300px;z-index:5;
}
.trending-l{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;font-weight:700;margin-bottom:6px}
.trending-t{font-size:13px;font-weight:600;line-height:1.4;color:var(--text)}
.trending-m{font-size:10px;color:var(--text4);margin-top:4px;font-family:'IBM Plex Mono',monospace}

/* Status */
.status{
  position:absolute;top:20px;right:24px;font-size:10px;color:var(--text3);
  background:var(--glass);border:1px solid var(--border);border-radius:20px;
  padding:6px 14px;font-family:'IBM Plex Mono',monospace;letter-spacing:.5px;
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);z-index:5;
  display:flex;align-items:center;gap:6px;
}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--amber)}
.status.ok .status-dot{background:var(--green);animation:pulse 2s infinite}
.status.err .status-dot{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

@media(max-width:768px){
  .header{padding:12px;gap:10px}
  .logo-t{font-size:15px}
  .logo-t small{display:none}
  .chips{order:3;width:100%}
  .search{order:2;max-width:none}
  .hint{display:none}
  .trending{display:none}
  .controls{bottom:14px;right:14px}
}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="bg-orb a"></div>
<div class="bg-orb b"></div>

<div class="app">
  <header class="header">
    <div class="logo">
      <div class="logo-mark">🌐</div>
      <div class="logo-t">WorldWire<small>Global news explorer</small></div>
    </div>
    <div class="search">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Search any country..." autocomplete="off">
      <div class="search-results" id="searchResults"></div>
    </div>
    <div class="chips" id="continentChips">
      <button class="chip on" data-continent="">All</button>
      <button class="chip" data-continent="EU">Europe</button>
      <button class="chip" data-continent="AS">Asia</button>
      <button class="chip" data-continent="AM">Americas</button>
      <button class="chip" data-continent="AF">Africa</button>
      <button class="chip" data-continent="OC">Oceania</button>
    </div>
    <div class="lang-toggle">
      <button class="lang-btn on" data-lang="">All</button>
      <button class="lang-btn" data-lang="eng">English</button>
    </div>
  </header>
  <main class="main">
    <svg class="map-svg" id="map"></svg>
    <div class="trending" id="trending">
      <div class="trending-l">🔥 Trending Globally</div>
      <div class="trending-t" id="trendingTitle">Loading top stories…</div>
      <div class="trending-m" id="trendingMeta"></div>
    </div>
    <div class="status" id="status"><span class="status-dot"></span><span id="statusText">Loading map…</span></div>
    <div class="controls">
      <button class="ctrl" id="zoomIn" title="Zoom in">+</button>
      <button class="ctrl" id="zoomOut" title="Zoom out">−</button>
      <button class="ctrl" id="zoomReset" title="Reset view">⌂</button>
    </div>
    <div class="hint">
      <div>Hover a country to see its top story</div>
      <div><span class="kbd">Click</span> to explore · <span class="kbd">Esc</span> to close</div>
    </div>
  </main>
</div>

<div class="tooltip" id="tooltip"></div>

<aside class="panel" id="panel">
  <div class="panel-head">
    <div class="panel-accent"></div>
    <div class="panel-top">
      <div>
        <div class="panel-flag" id="panelFlag">🌐</div>
        <div class="panel-name" id="panelName">Country</div>
        <div class="panel-meta" id="panelMeta"></div>
      </div>
      <button class="panel-close" onclick="closePanel()" title="Close (Esc)">×</button>
    </div>
    <div class="panel-stats">
      <div class="panel-stat"><strong id="statCount">—</strong>articles</div>
      <div class="panel-stat"><strong id="statSources">—</strong>sources</div>
      <div class="panel-stat"><strong id="statWindow">24h</strong>window</div>
    </div>
  </div>
  <div class="panel-body" id="panelBody"></div>
</aside>

<script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3"></script>
